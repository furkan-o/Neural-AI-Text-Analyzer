{
  "manifest_version": 3,
  "name": "Neural AI Text Analyzer",
  "version": "1.0",
  "description": "Seçilen metnin AI olup olmadığını Gemini 3.1 Flash-Lite ile analiz eder.",
  "permissions": ["contextMenus", "storage"],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["neural-expressive.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}